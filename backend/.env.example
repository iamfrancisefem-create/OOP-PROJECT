# =============================================================================
# Project Management System — Environment Configuration Template
# Rename this file to .env and fill in the production values.
# =============================================================================

# Database Config
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Security / JWT Config
# Generate a secure 256-bit base64-encoded key
JWT_SECRET=c2VjdXJlLWp3dC1zZWNyZXQta2V5LWZvci1wcm9qZWN0LW1hbmFnZW1lbnQtc3lzdGVt

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# File Upload Location
FILE_UPLOAD_DIR=./uploads

# SMTP / Mail Service Config (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
